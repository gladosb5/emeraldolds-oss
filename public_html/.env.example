# =============================================================================
# emeraldolds Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by Database.php's bootEnvironment().
# NEVER commit your actual .env file to version control.
# =============================================================================

# --- Database ---
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=emeraldnews

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost/Login/callback.php

# --- Discord Webhooks ---
DISCORD_WEBHOOK_URL_CATALOG=
DISCORD_WEBHOOK_URL_RCC=
DISCORD_WEBHOOK_URL_REPORT=

# --- Server Controller API Key ---
SERVER_API_KEY=your_api_key_here

# --- Advertising (optional, leave empty to disable) ---
# Set ADS_ENABLED=true and provide script URLs to enable ads
ADS_ENABLED=false
AD_SCRIPT_URL_1=

# Header ad block
AD_KEY_HEADER=
AD_SCRIPT_URL_HEADER=

# Footer ad block
AD_KEY_FOOTER=
AD_SCRIPT_URL_FOOTER=

# Inline ad block (getad.php)
AD_KEY_GETAD=
AD_SCRIPT_URL_GETAD=
